acl "trusted" {
  localhost;
  172.20.0.0/24;
};

options {
  directory "/var/cache/bind";
  listen-on { any; };
  listen-on-v6 { any; };

  recursion yes;
  allow-recursion { trusted; };
  allow-transfer { none; };
  allow-update { none; };

  forwarders {
    1.1.1.1;
    1.0.0.1;
  };

  dnssec-validation auto;
};
